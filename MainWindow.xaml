<Window x:Class="DatabaseManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewmodels="clr-namespace:DatabaseManager.ViewModels"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="Gestionnaire de Bases de Données" Height="700" Width="1200"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI" FontSize="14"
        Background="#1E1E1E">
    <Window.Resources>
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#3E3E42"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlDarkBrushKey}" Color="#2D2D30"/>
        
        <Style TargetType="Button">
            <Setter Property="Background" Value="#4A4A4E" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center" 
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.8" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.6" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.3" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Window.DataContext>
        <viewmodels:MainViewModel />
    </Window.DataContext>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- COLONNE GAUCHE : LISTE DES PROFILS -->
        <Border Grid.Column="0" Background="#2D2D30" Margin="0" CornerRadius="0">
            <Grid Margin="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="Connexions" FontWeight="SemiBold" FontSize="16" Foreground="#FFFFFF" Margin="0,0,0,15" />

                <!-- ListView pour la liste des profils -->
                <ListView Grid.Row="1" ItemsSource="{Binding SavedConnections}" SelectedItem="{Binding SelectedConnection}" 
                          BorderThickness="0" Background="#3E3E42" ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="10,8">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14" Foreground="#FFFFFF" />
                                <TextBlock Text="{Binding DatabaseType}" Foreground="#CCCCCC" FontSize="11" Margin="0,2,0,0" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Foreground" Value="White" />
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#007ACC" />
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#4A4A4E" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>

                <!-- Boutons Ajouter / Supprimer -->
                <UniformGrid Grid.Row="2" Columns="2" Margin="0,15,0,0">
                    <Button Content="Ajouter" Command="{Binding AddConnectionCommand}" 
                            Background="#007ACC" Foreground="White" BorderThickness="0" Padding="0,8" Margin="0,0,5,0" FontWeight="SemiBold" Cursor="Hand" />
                    <Button Content="Supprimer" Command="{Binding DeleteConnectionCommand}" 
                            Background="#D9534F" Foreground="White" BorderThickness="0" Padding="0,8" Margin="5,0,0,0" FontWeight="SemiBold" Cursor="Hand" />
                </UniformGrid>
            </Grid>
        </Border>

        <!-- COLONNE DROITE : FORMULAIRE OU TREEVIEW -->
        <Grid Grid.Column="1" Margin="15">
            <!-- Formulaire de configuration -->
            <Border Background="#2D2D30" CornerRadius="8" Padding="25">
                <Border.Effect>
                    <DropShadowEffect Color="Black" Opacity="0.3" BlurRadius="10" ShadowDepth="2"/>
                </Border.Effect>
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding SelectedConnection}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Détails du Profil" FontWeight="Bold" FontSize="20" Foreground="#FFFFFF" Margin="0,0,0,20" />

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Text="Nom du profil" FontWeight="SemiBold" Foreground="#CCCCCC" Margin="0,0,0,5" />
                            <TextBox Text="{Binding SelectedConnection.Name, UpdateSourceTrigger=PropertyChanged}" Padding="8" Margin="0,0,0,15" BorderBrush="#3E3E42" BorderThickness="1" Background="#3E3E42" Foreground="White" />

                            <TextBlock Text="Type de base de données" FontWeight="SemiBold" Foreground="#CCCCCC" Margin="0,0,0,5" />
                            <ComboBox ItemsSource="{Binding DatabaseTypes}" SelectedItem="{Binding SelectedConnection.DatabaseType}" Padding="8" Margin="0,0,0,15" BorderBrush="#3E3E42" BorderThickness="1" Background="White" Foreground="Black">
                                <ComboBox.Resources>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#3E3E42"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="White"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#007ACC"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White"/>
                                </ComboBox.Resources>
                                <ComboBox.ItemContainerStyle>
                                    <Style TargetType="ComboBoxItem">
                                        <Setter Property="Background" Value="#3E3E42" />
                                        <Setter Property="Foreground" Value="White" />
                                        <Setter Property="Padding" Value="6,4" />
                                        <Style.Triggers>
                                            <Trigger Property="IsHighlighted" Value="True">
                                                <Setter Property="Background" Value="#007ACC" />
                                                <Setter Property="Foreground" Value="White" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#005A9E" />
                                                <Setter Property="Foreground" Value="White" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ComboBox.ItemContainerStyle>
                            </ComboBox>

                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="20" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Hôte (Host)" FontWeight="SemiBold" Foreground="#CCCCCC" Margin="0,0,0,5" />
                                    <TextBox Text="{Binding SelectedConnection.Host, UpdateSourceTrigger=PropertyChanged}" Padding="8" BorderBrush="#3E3E42" BorderThickness="1" Background="#3E3E42" Foreground="White" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Port" FontWeight="SemiBold" Foreground="#CCCCCC" Margin="0,0,0,5" />
                                    <TextBox Text="{Binding SelectedConnection.Port, UpdateSourceTrigger=PropertyChanged}" Padding="8" BorderBrush="#3E3E42" BorderThickness="1" Background="#3E3E42" Foreground="White" />
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="20" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Utilisateur" FontWeight="SemiBold" Foreground="#CCCCCC" Margin="0,0,0,5" />
                                    <TextBox Text="{Binding SelectedConnection.Username, UpdateSourceTrigger=PropertyChanged}" Padding="8" BorderBrush="#3E3E42" BorderThickness="1" Background="#3E3E42" Foreground="White" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Mot de passe" FontWeight="SemiBold" Foreground="#CCCCCC" Margin="0,0,0,5" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <PasswordBox x:Name="PasswordBox" Grid.Column="0" Padding="8" BorderBrush="#3E3E42" BorderThickness="1" Background="#3E3E42" PasswordChanged="PasswordBox_PasswordChanged" />
                                        <TextBox x:Name="PasswordTextBox" Grid.Column="0" Padding="8" BorderBrush="#3E3E42" BorderThickness="1" Background="#3E3E42" Foreground="White" Visibility="Collapsed" TextChanged="PasswordTextBox_TextChanged" />
                                        <Button Grid.Column="1" Content="👁️" Width="30" Margin="5,0,0,0" Click="TogglePasswordVisibility" ToolTip="Afficher/Masquer le mot de passe" />
                                    </Grid>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Base de données (Optionnel)" FontWeight="SemiBold" Foreground="#CCCCCC" Margin="0,0,0,5" />
                            <TextBox Text="{Binding SelectedConnection.DefaultDatabase, UpdateSourceTrigger=PropertyChanged}" Padding="8" Margin="0,0,0,20" BorderBrush="#3E3E42" BorderThickness="1" Background="#3E3E42" Foreground="White" />
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Boutons Test & Connecter -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                        <Button Content="Tester la connexion" Command="{Binding TestConnectionCommand}"
                                Width="150" Padding="8,10" Margin="0,0,10,0" Background="#4A4A4E" BorderBrush="#4A4A4E" BorderThickness="1" Foreground="White" FontWeight="SemiBold" Cursor="Hand" />
                        <Button Content="Se Connecter" Command="{Binding ConnectCommand}"
                                Width="150" Padding="8,10" Background="#228B22" Foreground="White" BorderThickness="0" FontWeight="SemiBold" Cursor="Hand" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Message alternatif si aucune sélection -->
            <TextBlock Text="Veuillez sélectionner ou créer un profil à gauche." 
                       HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Foreground="#AAAAAA" FontWeight="SemiBold">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedConnection}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- TreeView pour la hiérarchie des bases de données (affiché quand connecté) -->
            <Grid>
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- COLONNE GAUCHE : EXPLORATEUR -->
                <Border Grid.Column="0" Background="#2D2D30" Margin="0" Padding="15">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Explorateur" FontWeight="SemiBold" FontSize="16" Foreground="#FFFFFF" Margin="0,0,0,15" />

                        <!-- Barre d'outils rapide -->
                        <UniformGrid Grid.Row="1" Columns="5" Margin="0,0,0,15">
                            <Button Content="+ Base" Command="{Binding CreateDatabaseCommand}"
                                    Background="#007ACC" Foreground="White" BorderThickness="0" Padding="0,6" Margin="0,0,5,0" FontWeight="SemiBold" Cursor="Hand" FontSize="11" ToolTip="Créer Base" />
                            <Button Content="- Base" Command="{Binding DeleteDatabaseCommand}"
                                    Background="#D9534F" Foreground="White" BorderThickness="0" Padding="0,6" Margin="0,0,5,0" FontWeight="SemiBold" Cursor="Hand" FontSize="11" ToolTip="Supprimer Base" />
                            <Button Content="+ Table" Command="{Binding CreateTableCommand}"
                                    Background="#007ACC" Foreground="White" BorderThickness="0" Padding="0,6" Margin="0,0,5,0" FontWeight="SemiBold" Cursor="Hand" FontSize="11" ToolTip="Créer Table" />
                            <Button Content="- Table" Command="{Binding DeleteTableCommand}"
                                    Background="#D9534F" Foreground="White" BorderThickness="0" Padding="0,6" Margin="0,0,5,0" FontWeight="SemiBold" Cursor="Hand" FontSize="11" ToolTip="Supprimer Table" />
                            <Button Content="🔄" Command="{Binding RefreshHierarchyCommand}"
                                    Background="#4A4A4E" Foreground="White" BorderThickness="0" Padding="0,6" Margin="0,0,0,0" FontWeight="SemiBold" Cursor="Hand" FontSize="11" ToolTip="Rafraîchir" />
                        </UniformGrid>

                        <StackPanel Grid.Row="2" Margin="0,0,0,15">
                            <TextBlock Text="Base de données active" FontWeight="SemiBold" Foreground="#CCCCCC" Margin="0,0,0,5" FontSize="12" />
                            <ComboBox ItemsSource="{Binding AvailableDatabases}" SelectedItem="{Binding SelectedDatabaseForQuery}"
                                      Padding="6" BorderBrush="#555555" BorderThickness="1" Background="White" Foreground="Black">
                                <ComboBox.Resources>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#3E3E42"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="White"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#007ACC"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White"/>
                                </ComboBox.Resources>
                                <ComboBox.ItemContainerStyle>
                                    <Style TargetType="ComboBoxItem">
                                        <Setter Property="Background" Value="#3E3E42" />
                                        <Setter Property="Foreground" Value="White" />
                                        <Setter Property="Padding" Value="6,4" />
                                        <Style.Triggers>
                                            <Trigger Property="IsHighlighted" Value="True">
                                                <Setter Property="Background" Value="#007ACC" />
                                                <Setter Property="Foreground" Value="White" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#005A9E" />
                                                <Setter Property="Foreground" Value="White" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ComboBox.ItemContainerStyle>
                            </ComboBox>
                        </StackPanel>

                        <TreeView Grid.Row="3" ItemsSource="{Binding DatabaseNodes}" BorderThickness="0" Background="#3E3E42">
                            <TreeView.ContextMenu>
                                <ContextMenu Background="#2D2D30" Foreground="White">
                                    <MenuItem Header="Créer une base de données" Command="{Binding CreateDatabaseCommand}" />
                                    <MenuItem Header="Supprimer la base de données" Command="{Binding DeleteDatabaseCommand}" />
                                    <Separator />
                                    <MenuItem Header="Créer une table" Command="{Binding CreateTableCommand}" />
                                    <MenuItem Header="Supprimer la table" Command="{Binding DeleteTableCommand}" />
                                </ContextMenu>
                            </TreeView.ContextMenu>
                            <TreeView.ItemTemplate>
                                <HierarchicalDataTemplate ItemsSource="{Binding Tables}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🗄️ " FontSize="12" />
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13" Foreground="#FFFFFF" />
                                    </StackPanel>
                                    <HierarchicalDataTemplate.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}" FontSize="12" Foreground="#E0E0E0">
                                                <TextBlock.InputBindings>
                                                    <MouseBinding Gesture="LeftDoubleClick" Command="{Binding DataContext.SelectTableCommand, RelativeSource={RelativeSource AncestorType=TreeView}}" CommandParameter="{Binding}" />
                                                </TextBlock.InputBindings>
                                            </TextBlock>
                                        </DataTemplate>
                                    </HierarchicalDataTemplate.ItemTemplate>
                                </HierarchicalDataTemplate>
                            </TreeView.ItemTemplate>
                            <TreeView.ItemContainerStyle>
                                <Style TargetType="TreeViewItem">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="Foreground" Value="White" />
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#007ACC" />
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#4A4A4E" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TreeView.ItemContainerStyle>
                        </TreeView>

                        <Button Grid.Row="4" Content="Se Déconnecter" Command="{Binding DisconnectCommand}" 
                                HorizontalAlignment="Stretch" Padding="8,10" Margin="0,15,0,0" 
                                Background="#D9534F" Foreground="White" BorderThickness="0" FontWeight="SemiBold" Cursor="Hand" />
                    </Grid>
                </Border>

                <!-- COLONNE DROITE : ÉDITEUR DE REQUÊTES -->
                <Border Grid.Column="1" Background="#2D2D30" CornerRadius="8" Margin="15" Padding="20">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" Opacity="0.3" BlurRadius="10" ShadowDepth="2"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="150" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Éditeur de Requêtes" FontWeight="SemiBold" FontSize="16" Foreground="#FFFFFF" Margin="0,0,0,10" />

                        <TextBox Grid.Row="1" Text="{Binding QueryText, UpdateSourceTrigger=PropertyChanged}" 
                                 AcceptsReturn="True" VerticalScrollBarVisibility="Auto" 
                                 Padding="10" BorderBrush="#3E3E42" BorderThickness="1" 
                                 FontFamily="Consolas" FontSize="13" Background="#3E3E42" Foreground="White"
                                 TextWrapping="Wrap" />

                        <Button Grid.Row="2" Content="Exécuter la requête" Command="{Binding ExecuteQueryCommand}" 
                                Width="180" Padding="8,10" Margin="0,10,0,0" HorizontalAlignment="Left" 
                                Background="#228B22" Foreground="White" BorderThickness="0" FontWeight="SemiBold" Cursor="Hand" />

                        <Border Grid.Row="3" BorderBrush="#3E3E42" BorderThickness="1" CornerRadius="4" Margin="0,10,0,0" Background="#3E3E42">
                            <DataGrid ItemsSource="{Binding QueryResult}" AutoGenerateColumns="True"
                                      CanUserAddRows="False" CanUserDeleteRows="False"
                                      IsReadOnly="False" Background="#3E3E42" BorderThickness="0"
                                      AlternatingRowBackground="#4A4A4E" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#3E3E42"
                                      RowBackground="#3E3E42" AlternationCount="2" Foreground="White">
                                <DataGrid.Style>
                                    <Style TargetType="DataGrid">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding QueryResult}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.Style>
                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="#2D2D30" />
                                        <Setter Property="Foreground" Value="#FFFFFF" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                        <Setter Property="HorizontalContentAlignment" Value="Left" />
                                        <Setter Property="Padding" Value="8,4" />
                                        <Setter Property="BorderBrush" Value="#3E3E42" />
                                        <Setter Property="BorderThickness" Value="0,0,0,1" />
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>
                            </DataGrid>
                        </Border>

                        <Button Grid.Row="4" Content="Sauvegarder les modifications" Command="{Binding SaveChangesCommand}" 
                                Width="200" Padding="8,10" Margin="0,10,0,0" HorizontalAlignment="Left" 
                                Background="#007ACC" Foreground="White" BorderThickness="0" FontWeight="SemiBold" Cursor="Hand" />

                        <TextBlock Grid.Row="3" Text="Aucun résultat à afficher" 
                                   HorizontalAlignment="Center" VerticalAlignment="Center" 
                                   FontSize="14" Foreground="#AAAAAA" FontStyle="Italic">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding QueryResult}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
